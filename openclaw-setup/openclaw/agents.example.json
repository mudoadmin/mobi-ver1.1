        "delegationMode": "prefer",
        "allowAgents": [
          "orchestrator-agent",
          "research-agent",
          "doc-agent",
          "build-agent",
          "build-agent-2",
          "build-agent-3",
          "build-agent-4",
          "qa-agent",
          "browser-agent",
          "integrator-agent",
          "render-agent",
          "image-draft-agent",
          "image-final-agent"
        ]
      }
    },
    {
